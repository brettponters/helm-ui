{
  "name": "helm",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "helm": "concurrently --names broker,pty,ui --prefix-colors white,cyan,gray \"node helm-broker/broker.js\" \"node helm-broker/pty-server.js\" \"vite --port 5199\"",
    "app": "electron .",
    "app:dist": "npm run build && electron-builder",
    "broker": "node helm-broker/broker.js",
    "pty": "node helm-broker/pty-server.js",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "setup-chat": "node scripts/setup-teammates.mjs",
    "postinstall": "node scripts/fix-pty-helper.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^6.0.0",
    "concurrently": "^10.0.3",
    "lucide-react": "^1.17.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.helm.terminal",
    "productName": "Helm",
    "asar": false,
    "afterPack": "electron/after-pack.cjs",
    "afterSign": "electron/notarize.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**",
      "helm-broker/**",
      "scripts/**",
      "dist/**",
      "package.json"
    ],
    "mac": {
      "target": [
        "dir"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    }
  }
}